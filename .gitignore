# =========================================================
# Local database
# =========================================================
/database/*.sqlite
/database/*.sqlite-*
/database/*.db
/database/*.db-*

# =========================================================
# Runtime storage
# =========================================================
/storage/backups/*
/storage/exports/*

!/storage/backups/.gitkeep
!/storage/exports/.gitkeep

# =========================================================
# Personal / private checklists
# =========================================================
/data/checklists/mine/
/data/checklists/private/
/data/checklists/local/

# =========================================================
# Editor / local tools
# =========================================================
.vscode/
.history/
.idea/

# =========================================================
# OS files
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# Logs
# =========================================================
*.log

# =========================================================
# Archives
# =========================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# =========================================================
# Environment files
# =========================================================
.env
.env.*
!.env.example

# =========================================================
# Dependencies if added later
# =========================================================
/vendor/
/node_modules/